{
  "name": "@tywalk/pcf-helper-run",
  "version": "1.3.2",
  "description": "Unified CLI interface for Power Platform Component Framework (PCF) development — init, build, import, deploy, and manage PCF controls in Dataverse.",
  "main": "dist/index.js",
  "types": "./types/",
  "files": [
    "dist",
    "types"
  ],
  "repository": {
    "url": "git+https://github.com/tywalk/pcf-helper.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "upgrade": "npm version patch --no-git-tag-version",
    "ready": "npm run upgrade && npm run build",
    "update": "npm run ready && npm publish --access public"
  },
  "keywords": [
    "pcf",
    "pcf-control",
    "pcf-component",
    "power-platform",
    "powerapps",
    "power-apps",
    "dataverse",
    "dynamics-365",
    "microsoft",
    "cli",
    "command-line",
    "developer-tools",
    "build-tool",
    "deployment",
    "automation",
    "typescript",
    "pac"
  ],
  "license": "MIT",
  "author": "tywalk",
  "homepage": "https://github.com/tywalk/pcf-helper#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "bin": {
    "pcf-helper-run": "dist/index.js"
  },
  "dependencies": {
    "@tywalk/color-logger": "^1.0.3",
    "@tywalk/pcf-helper": "^1.9.3"
  },
  "devDependencies": {
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.3",
    "jest": "^29.7.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
